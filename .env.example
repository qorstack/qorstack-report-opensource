# Qorstack Report — copy to .env and fill in your values

# Admin (created on first startup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=YourStrongPassword123!

# Database
DB_PASSWORD=your-strong-db-password

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your-minio-secret-here

# JWT — generate: openssl rand -hex 32
JWT_KEY=your-jwt-secret-at-least-32-chars

# Encryption
# ENCRYPTION_KEY: 32 chars — generate: openssl rand -hex 16
# ENCRYPTION_IV:  16 chars — generate: openssl rand -hex 8
ENCRYPTION_KEY=your-32-char-encryption-key-here!!
ENCRYPTION_IV=your-16-char-iv!!

# --- Optional ---

# API_URL=http://localhost:8080           # URL your browser uses to reach the API
# CORS_ORIGINS=http://localhost:3000      # comma-separated allowed origins
# MINIO_PUBLIC_ENDPOINT=http://localhost:9000  # URL your browser uses to reach MinIO (for file previews)
#                                              # For remote server: http://<server-ip>:9000

# External PostgreSQL (remove the postgres service from docker-compose.yml if used)
# DB_HOST=qorstack-postgres
# DB_PORT=5432
# DB_NAME=qorstack_report
# DB_USER=postgres

# External MinIO (remove the minio service from docker-compose.yml if used)
# MINIO_ENDPOINT=qorstack-minio:9000
# MINIO_USE_SSL=false
